# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_commerce_ads
DB_USER=aca_user
DB_PASSWORD=super_secret_password

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_string_for_refresh
JWT_REFRESH_EXPIRES_IN=30d

# ─── EMAIL (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@aicommerceads.com

# ─── STRIPE ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_SCALE=price_xxxxxxxxxxxxxxxxxxxx

# ─── META / FACEBOOK ──────────────────────────────────────────────────────────
META_APP_ID=xxxxxxxxxxxxxxxxxxxx
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
META_API_VERSION=v19.0
META_WEBHOOK_VERIFY_TOKEN=your_verify_token

# ─── WHATSAPP BUSINESS ────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxxxxxx
WHATSAPP_BUSINESS_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
WHATSAPP_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ─── ENCRYPTION ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_this_to_a_64_char_hex_string_from_openssl_rand_hex_32

# ─── OPENAI / ANTHROPIC (AI features) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ─── HUGGINGFACE (generación de imágenes con FLUX.1-schnell) ──────────────────
# Obtener en: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx

# ─── CLOUDFLARE R2 (video/image storage) ──────────────────────────────────────
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=aca-creatives
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
