# ─────────────────────────────────────────────────────────────────────────────
# CyV-Automatizada — Variables de entorno
# Copiá este archivo como .env.prod y completá los valores reales
# NUNCA commitees .env.prod al repositorio
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://tudominio.com

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ai_commerce_ads
DB_USER=aca_user
DB_PASSWORD=cambia_esta_password_segura

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=cambia_esta_password_redis

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=genera_un_secreto_con_openssl_rand_base64_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=genera_otro_secreto_diferente_al_anterior
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@tudominio.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_SCALE=price_xxxxxxxxxxxxxxxxxxxx

# ── Meta Ads API ──────────────────────────────────────────────────────────────
META_APP_ID=xxxxxxxxxxxxxxxxxxxx
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
META_API_VERSION=v19.0
META_WEBHOOK_VERIFY_TOKEN=genera_un_token_aleatorio

# ── WhatsApp Business ─────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxxxxxx
WHATSAPP_BUSINESS_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxx

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── OpenAI (opcional) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Cloudflare R2 (almacenamiento de creativos) ───────────────────────────────
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=cyv-creatives
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Encriptación ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY=genera_con_openssl_rand_hex_32

# ── Deploy (Docker Compose prod) ─────────────────────────────────────────────
GITHUB_REPO=tu-usuario/CyV-Automatizada
IMAGE_TAG=latest
